# =========================================================
# SHAP wrapper
# =========================================================
class _GlobalScoreWrapper(nn.Module):
    def __init__(
        self,
        full_model: nn.Module,
        outputs_cache: Dict[str, torch.Tensor],
        global_dim: int,
        num_regions: int,
        region_dim: int,
        manual_forward_fn,
    ) -> None:
        super().__init__()
        self.full_model = full_model
        self.outputs_cache = outputs_cache
        self.global_dim = int(global_dim)
        self.num_regions = int(num_regions)
        self.region_dim = int(region_dim)
        self.manual_forward_fn = manual_forward_fn

    def _maybe_expand(self, value: Any, batch_size: int) -> Any:
        if value is None:
            return None
        if not torch.is_tensor(value):
            return value
        if value.dim() > 0 and value.size(0) == 1 and batch_size > 1:
            expand_sizes = [batch_size] + [-1] * (value.dim() - 1)
            return value.expand(*expand_sizes).clone()
        return value.clone()

    def forward(self, x: torch.Tensor) -> torch.Tensor:
        device = self.outputs_cache["deep_global_feature"].device
        x = x.to(device)
        handcrafted_global = x[:, :self.global_dim]
        handcrafted_region = x[:, self.global_dim:].reshape(-1, self.num_regions, self.region_dim)

        batch_size = handcrafted_global.size(0)
        outputs_cache: Dict[str, Any] = {k: self._maybe_expand(v, batch_size) for k, v in self.outputs_cache.items()}

        out = self.manual_forward_fn(
            self.full_model,
            outputs_cache,
            handcrafted_global,
            handcrafted_region,
            apply_region_dropout=False,
        )

        y = out["final_score_10"]
        if y.ndim == 1:
            y = y.unsqueeze(-1)
        elif y.ndim > 2:
            y = y.reshape(y.shape[0], -1)[:, :1]
        return y


# =========================================================
# 解释器
# =========================================================
class ExplainabilityEngineStrictOriginalDesign:
    def __init__(
        self,
        region_names: Sequence[str],
        global_feature_names: Sequence[str],
        region_feature_names: Sequence[str],
        manual_forward_fn,
    ) -> None:
        self.region_names = list(region_names)
        self.global_feature_names = list(global_feature_names)
        self.region_feature_names = list(region_feature_names)
        self.manual_forward_fn = manual_forward_fn

    def _flatten_features(self, hg: torch.Tensor, hr: torch.Tensor) -> torch.Tensor:
        return torch.cat([hg, hr.flatten(start_dim=1)], dim=1)

    def _flat_feature_names(self, global_dim: int, region_dim: int) -> List[str]:
        gnames = self.global_feature_names if len(self.global_feature_names) == global_dim else [f"global_feat_{i}" for i in range(global_dim)]
        rnames = self.region_feature_names if len(self.region_feature_names) == region_dim else [f"region_feat_{i}" for i in range(region_dim)]
        out = [f"global_{n}" for n in gnames]
        for region_name in self.region_names:
            for fname in rnames:
                out.append(f"{region_name}_{fname}")
        return out

    def compute_global_shap(
        self,
        model: nn.Module,
        outputs: Dict[str, torch.Tensor],
        background_global: torch.Tensor,
        background_region: torch.Tensor,
        sample_global: torch.Tensor,
        sample_region: torch.Tensor,
    ) -> Tuple[np.ndarray, float, str, List[str], np.ndarray]:
        wrapper = _GlobalScoreWrapper(
            full_model=model,
            outputs_cache=outputs,
            global_dim=sample_global.size(-1),
            num_regions=sample_region.size(1),
            region_dim=sample_region.size(2),
            manual_forward_fn=self.manual_forward_fn,
        ).eval()

        device = outputs["deep_global_feature"].device
        bg = self._flatten_features(background_global.to(device), background_region.to(device))
        x = self._flatten_features(sample_global.to(device), sample_region.to(device))
        names = self._flat_feature_names(sample_global.size(-1), sample_region.size(2))

        if shap is None:
            x_grad = x.clone().detach().requires_grad_(True)
            y = wrapper(x_grad).sum()
            y.backward()
            vals = x_grad.grad.detach().cpu().numpy() * x.detach().cpu().numpy()
            base_value = float(wrapper(bg).mean().detach().cpu().item())
            return vals[0], base_value, "Grad*Input", names, x.detach().cpu().numpy()[0]

        try:
            explainer = shap.GradientExplainer(wrapper, bg)
            shap_values = explainer.shap_values(x)
            if isinstance(shap_values, list):
                shap_values = shap_values[0]
            shap_arr = np.asarray(shap_values, dtype=np.float32)
            expected_value = getattr(explainer, "expected_value", None)
            if isinstance(expected_value, (list, tuple, np.ndarray)):
                base_value = float(np.asarray(expected_value).reshape(-1)[0])
            elif expected_value is None:
                base_value = float(wrapper(bg).mean().detach().cpu().item())
            else:
                base_value = float(expected_value)
            return shap_arr[0], base_value, "GradientExplainer", names, x.detach().cpu().numpy()[0]
        except Exception:
            x_grad = x.clone().detach().requires_grad_(True)
            y = wrapper(x_grad).sum()
            y.backward()
            vals = x_grad.grad.detach().cpu().numpy() * x.detach().cpu().numpy()
            base_value = float(wrapper(bg).mean().detach().cpu().item())
            return vals[0], base_value, "Grad*Input", names, x.detach().cpu().numpy()[0]

    @staticmethod
    def _top_signed_features(
        shap_values: np.ndarray,
        feature_names: Sequence[str],
        feature_values: np.ndarray,
        top_k: int,
        region_name: Optional[str],
        exclude_meta: bool = True,
    ) -> Tuple[List[FeatureContribution], List[FeatureContribution]]:
        items: List[Tuple[str, float, float]] = []
        for fname, sval, fval in zip(feature_names, shap_values, feature_values):
            name = str(fname)
            if exclude_meta and name in META_FEATURES:
                continue
            items.append((name, float(sval), float(fval)))
        pos = sorted([x for x in items if x[1] > 0], key=lambda t: t[1], reverse=True)[:top_k]
        neg = sorted([x for x in items if x[1] < 0], key=lambda t: t[1])[:top_k]
        pos_items = [FeatureContribution(name, feature_display_name(name, region_name), fval, sval) for name, sval, fval in pos]
        neg_items = [FeatureContribution(name, feature_display_name(name, region_name), fval, sval) for name, sval, fval in neg]
        return pos_items, neg_items

    @staticmethod
    def _lowest_value_features(
        feature_names: Sequence[str],
        feature_values: np.ndarray,
        shap_values: np.ndarray,
        top_k: int,
        region_name: Optional[str],
        exclude_meta: bool = True,
    ) -> List[FeatureContribution]:
        items: List[Tuple[str, float, float]] = []
        for fname, fval, sval in zip(feature_names, feature_values, shap_values):
            name = str(fname)
            if exclude_meta and name in META_FEATURES:
                continue
            items.append((name, float(fval), float(sval)))
        lowest = sorted(items, key=lambda t: t[1])[:top_k]
        return [FeatureContribution(name, feature_display_name(name, region_name), fval, sval) for name, fval, sval in lowest]

    @staticmethod
    def compute_region_contributions_original_design(outputs: Dict[str, torch.Tensor]) -> Optional[torch.Tensor]:
        region_weights = outputs.get("region_weights")
        region_scores = outputs.get("region_scores")
        region_padding_mask = outputs.get("region_padding_mask")
        if region_weights is None or region_scores is None:
            return None
        contributions = region_weights * (region_scores - 0.5)
        if region_padding_mask is not None:
            contributions = contributions.masked_fill(region_padding_mask, 0.0)
        return contributions

    def aggregate_region_shap(self, shap_values_flat: np.ndarray, global_dim: int, region_dim: int) -> np.ndarray:
        region_sums = []
        for ridx, _ in enumerate(self.region_names):
            start = global_dim + ridx * region_dim
            end = start + region_dim
            local_vals = shap_values_flat[start:end]
            usable = [float(sval) for fname, sval in zip(self.region_feature_names, local_vals) if fname not in META_FEATURES]
            region_sums.append(float(np.sum(usable)) if usable else 0.0)
        return np.asarray(region_sums, dtype=np.float32)

    def build_region_explanations(
        self,
        outputs: Dict[str, torch.Tensor],
        shap_values_flat: np.ndarray,
        flat_input: np.ndarray,
        visual_detected_mask: Optional[torch.Tensor],
        visual_area_ratio: Optional[torch.Tensor],
        visual_peak_conf: Optional[torch.Tensor],
        defect_threshold: float = 6.0,
        advantage_threshold: float = 7.5,
    ) -> List[RegionExplanation]:
        region_scores_norm = outputs.get("region_scores", None)
        region_scores_10 = outputs.get("region_scores_10", None)
        region_weights = outputs.get("region_weights", None)
        region_padding_mask = outputs.get("region_padding_mask", None)

        global_dim = len(self.global_feature_names)
        region_dim = len(self.region_feature_names)
        region_shap_sums = self.aggregate_region_shap(shap_values_flat, global_dim, region_dim)
        # 仅修复区域贡献计算：主展示口径改为“区域特征组在 final_score 路径上的 SHAP 聚合贡献”。
        # 这样可保持现有打印/可视化/字段名不变，同时避免与区域级 SHAP 正负号冲突。
        model_region_contrib = region_shap_sums
        region_items: List[RegionExplanation] = []

        for ridx, rname in enumerate(self.region_names):
            rdisplay = region_display_name(rname)
            detected_valid = True
            if region_padding_mask is not None:
                detected_valid = not bool(region_padding_mask[0, ridx].item())
            detected_visual = False
            if visual_detected_mask is not None:
                detected_visual = bool(visual_detected_mask[0, ridx].item())
            area_ratio = 0.0
            if visual_area_ratio is not None:
                area_ratio = float(visual_area_ratio[0, ridx].item())
            peak_conf = 0.0
            if visual_peak_conf is not None:
                peak_conf = float(visual_peak_conf[0, ridx].item())

            rscore10 = float("nan")
            if region_scores_10 is not None and detected_valid and not torch.isnan(region_scores_10[0, ridx]):
                rscore10 = float(region_scores_10[0, ridx].item())
            rscore_norm = float("nan")
            if region_scores_norm is not None and detected_valid and not torch.isnan(region_scores_norm[0, ridx]):
                rscore_norm = float(region_scores_norm[0, ridx].item())
            rweight = 0.0
            if region_weights is not None:
                try:
                    rweight = float(region_weights[0, ridx].item())
                except Exception:
                    rweight = 0.0
            rcontrib = 0.0
            if model_region_contrib is not None:
                try:
                    # model_region_contrib 现在直接使用 region_shap_sums（numpy 向量）
                    rcontrib = float(model_region_contrib[ridx])
                except Exception:
                    rcontrib = 0.0

            start = global_dim + ridx * region_dim
            end = start + region_dim
            local_shap = shap_values_flat[start:end]
            local_input = flat_input[start:end]
            pos_feats, neg_feats = self._top_signed_features(local_shap, self.region_feature_names, local_input, 3, rname, True)
            lowest_feats = self._lowest_value_features(self.region_feature_names, local_input, local_shap, 3, rname, True)

            is_defect = bool(detected_valid and not np.isnan(rscore10) and rscore10 < defect_threshold)
            is_advantage = bool(detected_valid and not np.isnan(rscore10) and rscore10 > advantage_threshold)

            if not detected_visual and not detected_valid:
                sentence = f"{rdisplay}未检测到，也未参与评分。"
            elif detected_visual and not detected_valid:
                sentence = f"{rdisplay}在视觉上被检测到，但未作为有效区域参与评分。"
            elif not detected_valid:
                sentence = f"{rdisplay}未作为有效区域参与评分。"
            elif is_defect:
                low_text = "、".join([
                    f"{x.feature_display_name}(value={x.feature_value:.3f}, SHAP{x.shap_value:+.3f})" for x in lowest_feats
                ]) or "暂无明显低分特征"
                sentence = (
                    f"{rdisplay}子评分为 {rscore10:.2f}/10；按原始设计贡献定义，其区域贡献为 {rcontrib:+.3f}；"
                    f"该区域属于缺陷区域，主要低值特征为：{low_text}。"
                )
            elif is_advantage:
                good_text = "、".join([
                    f"{x.feature_display_name}(value={x.feature_value:.3f}, SHAP{x.shap_value:+.3f})" for x in pos_feats
                ]) or "暂无明显正向特征"
                sentence = (
                    f"{rdisplay}子评分为 {rscore10:.2f}/10；按原始设计贡献定义，其区域贡献为 {rcontrib:+.3f}；"
                    f"该区域属于优势区域，主要正向 SHAP 特征为：{good_text}。"
                )
            else:
                mix_text = "、".join([
                    f"{x.feature_display_name}(value={x.feature_value:.3f}, SHAP{x.shap_value:+.3f})" for x in (pos_feats[:1] + neg_feats[:1])
                ]) or "无明显突出特征"
                sentence = (
                    f"{rdisplay}子评分为 {rscore10:.2f}/10；按原始设计贡献定义，其区域贡献为 {rcontrib:+.3f}；"
                    f"区域级 SHAP 相关特征：{mix_text}。"
                )

            region_items.append(
                RegionExplanation(
                    region_index=ridx,
                    region_name=rname,
                    region_display_name=rdisplay,
                    detected_valid=detected_valid,
                    detected_visual=detected_visual,
                    area_ratio=area_ratio,
                    peak_confidence=peak_conf,
                    region_score_10=rscore10,
                    region_score_norm=rscore_norm,
                    region_weight=rweight,
                    region_contribution_score=rcontrib,
                    region_shap_attribution_score=float(region_shap_sums[ridx]),
                    is_defect=is_defect,
                    is_advantage=is_advantage,
                    positive_features=pos_feats,
                    negative_features=neg_feats,
                    lowest_features=lowest_feats,
                    sentence=sentence,
                )
            )
        return region_items

    def build_summary(
        self,
        final_score_10: float,
        global_pos: List[FeatureContribution],
        global_neg: List[FeatureContribution],
        region_exps: List[RegionExplanation],
        region_flat_pos: List[Dict[str, Any]],
        region_flat_neg: List[Dict[str, Any]],
        defect_threshold: float,
    ) -> str:
        text = f"整图美学评分为 {final_score_10:.2f}/10。"
        valid_regions = [x for x in region_exps if x.detected_valid]
        visual_regions = [x for x in region_exps if x.detected_visual]
        defects = [x for x in region_exps if x.is_defect]
        advantages = [x for x in region_exps if x.is_advantage]

        def fmt_region_item(x: RegionExplanation) -> str:
            if np.isnan(x.region_score_10):
                score_text = "N/A"
            else:
                score_text = f"{x.region_score_10:.2f}/10"
            return (
                f"{x.region_display_name}(面积{x.area_ratio:.3%}, 置信度{x.peak_confidence:.3f}, 子评分{score_text}, "
                f"区域贡献{x.region_contribution_score:+.3f})"
            )

        if visual_regions:
            visual_regions = sorted(visual_regions, key=lambda x: abs(x.region_contribution_score), reverse=True)
            text += " 检测到的区域及其模型区域贡献：" + "、".join([fmt_region_item(x) for x in visual_regions]) + "。"
        if valid_regions:
            valid_regions = sorted(valid_regions, key=lambda x: abs(x.region_contribution_score), reverse=True)
            text += " 参与评分的有效区域：" + "、".join([fmt_region_item(x) for x in valid_regions]) + "。"
        if global_pos:
            text += " 全局特征 SHAP 正向归因：" + "、".join([
                f"全局{x.feature_display_name}(value={x.feature_value:.3f}, SHAP{x.shap_value:+.3f})" for x in global_pos[:2]
            ]) + "。"
        if global_neg:
            text += " 全局特征 SHAP 负向归因：" + "、".join([
                f"全局{x.feature_display_name}(value={x.feature_value:.3f}, SHAP{x.shap_value:+.3f})" for x in global_neg[:2]
            ]) + "。"
        if region_flat_pos:
            text += " 区域特征 SHAP 正向归因：" + "、".join([
                f"{x['feature_display_name']}(value={x['feature_value']:.3f}, SHAP{x['shap_value']:+.3f})" for x in region_flat_pos[:3]
            ]) + "。"
        if region_flat_neg:
            text += " 区域特征 SHAP 负向归因：" + "、".join([
                f"{x['feature_display_name']}(value={x['feature_value']:.3f}, SHAP{x['shap_value']:+.3f})" for x in region_flat_neg[:3]
            ]) + "。"
        if advantages:
            top_adv = sorted(advantages, key=lambda x: x.region_score_10, reverse=True)[:2]
            text += " 优势区域：" + "、".join([fmt_region_item(x) for x in top_adv]) + "。"
        if defects:
            top_def = sorted(defects, key=lambda x: x.region_score_10)[:2]
            text += f" 缺陷定位（阈值<{defect_threshold:.0f}分）：" + " ".join([x.sentence for x in top_def])
        return text

    def explain(
        self,
        model: nn.Module,
        outputs: Dict[str, torch.Tensor],
        bg_global: torch.Tensor,
        bg_region: torch.Tensor,
        visual_detected_mask: Optional[torch.Tensor],
        visual_area_ratio: Optional[torch.Tensor],
        visual_peak_conf: Optional[torch.Tensor],
        defect_threshold: float = 6.0,
        advantage_threshold: float = 7.5,
    ) -> Dict[str, Any]:
        hg = outputs["raw_handcrafted_global"]
        hr = outputs["raw_handcrafted_region"]
        shap_values, base_value, shap_method, flat_names, flat_input = self.compute_global_shap(
            model=model,
            outputs=outputs,
            background_global=bg_global,
            background_region=bg_region,
            sample_global=hg,
            sample_region=hr,
        )

        global_dim = len(self.global_feature_names)
        global_shap = shap_values[:global_dim]
        global_input = flat_input[:global_dim]
        global_pos, global_neg = self._top_signed_features(global_shap, self.global_feature_names, global_input, 8, None, True)

        region_exps = self.build_region_explanations(
            outputs=outputs,
            shap_values_flat=shap_values,
            flat_input=flat_input,
            visual_detected_mask=visual_detected_mask,
            visual_area_ratio=visual_area_ratio,
            visual_peak_conf=visual_peak_conf,
            defect_threshold=defect_threshold,
            advantage_threshold=advantage_threshold,
        )
        region_flat_pos, region_flat_neg = collect_flat_scope_features(
            shap_values=shap_values,
            feature_names=flat_names,
            feature_values=flat_input,
            region_names=self.region_names,
            top_k=10,
            scope="region",
        )
        final_score_10 = float(outputs["final_score_10"][0].item())
        summary = self.build_summary(final_score_10, global_pos, global_neg, region_exps, region_flat_pos, region_flat_neg, defect_threshold)

        return {
            "final_score_10": final_score_10,
            "base_value": base_value,
            "shap_method": shap_method,
            "global_shap_values_flat": shap_values.tolist(),
            "global_feature_names_flat": flat_names,
            "flat_input": flat_input.tolist(),
            "global_positive_features": [asdict(x) for x in global_pos],
            "global_negative_features": [asdict(x) for x in global_neg],
            "region_positive_features_flat": region_flat_pos,
            "region_negative_features_flat": region_flat_neg,
            "region_explanations": [asdict(x) for x in region_exps],
            "visual_detected_regions": [x.region_name for x in region_exps if x.detected_visual],
            "valid_regions_for_scoring": [x.region_name for x in region_exps if x.detected_valid],
            "visual_detected_region_contributions": [
                {
                    "region_name": x.region_name,
                    "region_display_name": x.region_display_name,
                    "region_score_10": x.region_score_10,
                    "region_score_norm": x.region_score_norm,
                    "region_contribution_score": x.region_contribution_score,
                    "region_shap_attribution_score": x.region_shap_attribution_score,
                    "region_weight": x.region_weight,
                    "area_ratio": x.area_ratio,
                    "peak_confidence": x.peak_confidence,
                }
                for x in region_exps if x.detected_visual
            ],
            "valid_region_contributions": [
                {
                    "region_name": x.region_name,
                    "region_display_name": x.region_display_name,
                    "region_score_10": x.region_score_10,
                    "region_score_norm": x.region_score_norm,
                    "region_contribution_score": x.region_contribution_score,
                    "region_shap_attribution_score": x.region_shap_attribution_score,
                    "region_weight": x.region_weight,
                    "area_ratio": x.area_ratio,
                    "peak_confidence": x.peak_confidence,
                }
                for x in region_exps if x.detected_valid
            ],
            "summary": summary,
        }


