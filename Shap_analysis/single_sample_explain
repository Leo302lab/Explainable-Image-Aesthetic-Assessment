def _ensure_dir(path: str) -> None:
    os.makedirs(path, exist_ok=True)


def save_single_sample_waterfall(explanation_result: Dict[str, Any], save_path: str, max_display: int = 15) -> None:
    """
    使用统一论文配色绘制单样本 SHAP 分解图。
    为避免与其他图风格割裂，这里采用自定义的 waterfall-like 累积条形图，
    颜色与其它解释图保持一致：正向=粉，负向=蓝，背景=白色。
    """
    shap_vals = np.asarray(explanation_result["global_shap_values_flat"], dtype=np.float32).reshape(-1)
    base_value = float(explanation_result["base_value"])
    feature_names = [plot_label_from_feature_name(x) for x in explanation_result["global_feature_names_flat"]]
    pred_value = float(explanation_result.get("final_score_10", base_value + float(np.sum(shap_vals))))

    order = np.argsort(np.abs(shap_vals))[::-1]
    top_order = order[:max_display]
    other_sum = float(np.sum(shap_vals) - np.sum(shap_vals[top_order]))

    rows: List[Tuple[str, float]] = [
        (_clean_feature_label(feature_names[i], 36), float(shap_vals[i])) for i in top_order
    ]
    if abs(other_sum) > 1e-6:
        rows.append(("Other features", other_sum))

    # 从 base value 开始做累积贡献分解。
    starts = []
    widths = []
    colors = []
    running = base_value
    for _, delta in rows:
        starts.append(min(running, running + delta))
        widths.append(abs(delta))
        colors.append(COLOR_POS if delta >= 0 else COLOR_NEG)
        running += delta

    labels = [r[0] for r in rows]
    deltas = [r[1] for r in rows]
    y = np.arange(len(rows))

    x_min = min([base_value, pred_value] + starts)
    x_max = max([base_value, pred_value] + [s + w for s, w in zip(starts, widths)])
    x_pad = max((x_max - x_min) * 0.10, 0.08)

    fig, ax = plt.subplots(figsize=(11.6, max(4.6, 0.52 * len(rows) + 2.2)), facecolor=COLOR_FIG)
    _style_axis(ax, grid_axis="x")

    ax.barh(y, widths, left=starts, color=colors, edgecolor="none", height=0.64, alpha=0.92, zorder=3)

    # 连接线强调累积过程
    running = base_value
    for idx, delta in enumerate(deltas):
        next_running = running + delta
        ax.plot([running, running], [idx - 0.32, idx + 0.32], color=ZERO_LINE, lw=1.0, alpha=0.8, zorder=2)
        ax.plot([running, next_running], [idx, idx], color=ZERO_LINE, lw=1.0, alpha=0.55, zorder=2)
        running = next_running

    for idx, delta in enumerate(deltas):
        x_text = starts[idx] + widths[idx] + max((x_max - x_min) * 0.012, 0.01) if delta >= 0 else starts[idx] - max((x_max - x_min) * 0.012, 0.01)
        ax.text(
            x_text,
            idx,
            f"{delta:+.3f}",
            va="center",
            ha="left" if delta >= 0 else "right",
            fontsize=10,
            color=TEXT_COLOR,
        )

    ax.axvline(base_value, color=GRID_COLOR, lw=1.2, linestyle="--", zorder=1)
    ax.axvline(pred_value, color=ZERO_LINE, lw=1.3, zorder=1)
    ax.text(base_value, len(rows) + 0.08, f"Base {base_value:.2f}", ha="center", va="bottom", fontsize=10, color=AXIS_COLOR)
