def save_region_feature_heatmap(
    explanation_result: Dict[str, Any],
    region_names: Sequence[str],
    region_feature_names: Sequence[str],
    save_path: str,
    use_abs: bool = True,
) -> None:
    shap_vals = np.asarray(explanation_result["global_shap_values_flat"], dtype=np.float32)
    flat_names = list(explanation_result["global_feature_names_flat"])
    rows = []
    plot_region_names = [region_display_name_en(r) for r in region_names]
    plot_feat_names = [FEATURE_EN.get(f, f) for f in region_feature_names if f not in META_FEATURES]
    for region_name in region_names:
        row = []
        for feat_name in region_feature_names:
            if feat_name in META_FEATURES:
                continue
            full_name = f"{region_name}_{feat_name}"
            if full_name in flat_names:
                idx = flat_names.index(full_name)
                val = float(shap_vals[idx])
            else:
                val = 0.0
            row.append(abs(val) if use_abs else val)
        rows.append(row)
    data = np.asarray(rows, dtype=np.float32)

    fig, ax = plt.subplots(figsize=(11.2, 5.9), facecolor=COLOR_FIG)
    _style_axis(ax)
    cmap = PAPER_SEQ_CMAP if use_abs else PAPER_DIV_CMAP
    im = ax.imshow(data, aspect="auto", cmap=cmap)
    ax.set_xticks(np.arange(len(plot_feat_names)))
    ax.set_xticklabels(plot_feat_names, rotation=35, ha="right", fontsize=9, color=AXIS_COLOR)
    ax.set_yticks(np.arange(len(plot_region_names)))
    ax.set_yticklabels(plot_region_names, fontsize=10, color=AXIS_COLOR)
    ax.set_title("Region-feature SHAP heatmap", fontsize=14, pad=12, color=TEXT_COLOR)

    cbar = plt.colorbar(im, ax=ax, fraction=0.03, pad=0.03)
    cbar.set_label("|SHAP|" if use_abs else "SHAP", fontsize=11, color=AXIS_COLOR)
    cbar.ax.tick_params(labelsize=10, colors=AXIS_COLOR)
    cbar.outline.set_visible(False)
    cbar.ax.set_facecolor(COLOR_FIG)

    plt.tight_layout()
