def save_region_overview(
     region_explanations: List[Dict[str, Any]],
     save_path: str,
     defect_threshold: float = 6.0,
 ) -> None:
     """
     左图这种形式：
     - 左侧面板：区域子评分（横向条形图）
     - 右侧面板：区域贡献（横向条形图）
     - 背景统一白色
     - 配色沿用当前脚本统一论文配色
     """
     valid_items = [x for x in region_explanations if x["detected_valid"]]
     if len(valid_items) == 0:
         raise RuntimeError("没有有效区域可绘制。")

     names = [region_display_name_en(x["region_name"]) for x in valid_items]
     region_scores = np.asarray(
         [float(x["region_score_10"]) for x in valid_items], dtype=np.float32
     )
     region_contrib = np.asarray(
         [float(x["region_contribution_score"]) for x in valid_items], dtype=np.float32
     )

     y = np.arange(len(names), dtype=np.float32)
     contrib_colors = [
         REGION_CONTRIB_POS if v >= 0 else REGION_CONTRIB_NEG for v in region_contrib
     ]

     max_abs_contrib = float(np.max(np.abs(region_contrib))) if len(region_contrib) > 0 else 0.05
     max_abs_contrib = max(max_abs_contrib * 1.15, 0.02)

     fig, (ax_score, ax_contrib) = plt.subplots(
         1, 2,
         figsize=(11.8, 5.2),
         gridspec_kw={"width_ratios": [1.15, 1.0], "wspace": 0.08},
         facecolor=FIG_BG,
         sharey=True,
     )

     # 统一白底
     ax_score.set_facecolor(FIG_BG)
     ax_contrib.set_facecolor(FIG_BG)

     # ===== 左：区域子评分 =====
     bars_score = ax_score.barh(
         y,
         region_scores,
         color=REGION_SCORE_BAR,
         edgecolor="none",
         alpha=0.95,
         height=0.52,
         zorder=3,
     )

     ax_score.axvline(
         defect_threshold,
         color=DEFECT_LINE,
         linestyle="--",
         lw=1.2,
         alpha=0.95,
         zorder=2,
     )

     for yi, val in zip(y, region_scores):
         ax_score.text(
             val + 0.08,
             yi,
             f"{val:.2f}/10",
             va="center",
             ha="left",
             fontsize=10,
             color=TEXT_COLOR,
         )

     ax_score.set_yticks(y)
     ax_score.set_yticklabels(names, fontsize=11, color=AXIS_COLOR)
     ax_score.set_xlim(0, 10)
     ax_score.set_xlabel("Region sub-score (0-10)", fontsize=11, color=AXIS_COLOR)
     ax_score.set_title("Region sub-scores", fontsize=12, pad=10, color=TEXT_COLOR)
     ax_score.grid(axis="x", color=GRID_COLOR, linestyle="-", linewidth=0.6, alpha=0.35)
     ax_score.tick_params(axis="x", labelsize=10, colors=AXIS_COLOR)
     ax_score.tick_params(axis="y", labelsize=11, colors=AXIS_COLOR)

     # ===== 右：区域贡献 =====
     bars_contrib = ax_contrib.barh(
         y,
         region_contrib,
         color=contrib_colors,
         edgecolor="none",
         alpha=0.95,
         height=0.60,
         zorder=3,
     )

     ax_contrib.axvline(0.0, color=ZERO_LINE, lw=1.1, alpha=0.9, zorder=2)

     for yi, val in zip(y, region_contrib):
         if val >= 0:
             x_text = val + max_abs_contrib * 0.04
             ha = "left"
         else:
             x_text = val - max_abs_contrib * 0.04
             ha = "right"
         ax_contrib.text(
             x_text,
             yi,
             f"{val:+.3f}",
             va="center",
             ha=ha,
             fontsize=10,
             color=TEXT_COLOR,
         )

     ax_contrib.set_xlim(-max_abs_contrib, max_abs_contrib)
     ax_contrib.set_xlabel("Region contribution (original design)", fontsize=11, color=AXIS_COLOR)
     ax_contrib.set_title("Region contributions", fontsize=12, pad=10, color=TEXT_COLOR)
     ax_contrib.grid(axis="x", color=GRID_COLOR, linestyle="-", linewidth=0.6, alpha=0.35)
     ax_contrib.tick_params(axis="x", labelsize=10, colors=AXIS_COLOR)
     ax_contrib.tick_params(axis="y", left=False, labelleft=False)

     # 让第一个区域在最上面，和你左图一致
     ax_score.invert_yaxis()

     # 整体标题
     fig.suptitle("Region sub-scores and contributions", fontsize=14, y=0.98, color=TEXT_COLOR)

     # 去边框
     for ax in [ax_score, ax_contrib]:
         for spine in ["top", "right", "left", "bottom"]:
             ax.spines[spine].set_visible(False)

     plt.tight_layout(rect=[0, 0, 1, 0.95])
     # 同时保存 SVG 和 PNG 两份
     p = Path(save_path)
     stem_dir = str(p.with_suffix(""))
     plt.savefig(stem_dir + ".svg", format="svg", bbox_inches="tight", facecolor=fig.get_facecolor())
     plt.savefig(stem_dir + ".png", format="png", dpi=200, bbox_inches="tight", facecolor=fig.get_facecolor())
     plt.close(fig)


def save_mask_overlay_visualization(
    image_path: str,
    semantic_mask: torch.Tensor,
    region_names: Sequence[str],
    save_path: str,
    conf_threshold: float = 0.55,
    min_area_ratio: float = 0.002,
) -> None:
    """保存离线 semantic_mask 的可视化图。"""
    image = load_raw_image(image_path).astype(np.float32) / 255.0
    h, w = image.shape[:2]

    mask = semantic_mask.detach().cpu()
    if mask.ndim == 3:
        mask = mask[0]
    if mask.ndim != 2:
        raise ValueError(f"Expected semantic_mask to be [H,W] or [1,H,W], got {tuple(mask.shape)}")

    if mask.shape != (h, w):
        raise ValueError(f"semantic_mask shape {tuple(mask.shape)} != image shape {(h, w)}")

    label_np = mask.numpy().astype(np.int64)
    total = float(h * w)

    overlay = image.copy()
    legend_handles = []

    def _mask_edge(binary_mask: np.ndarray) -> np.ndarray:
        padded = np.pad(binary_mask.astype(np.uint8), 1, mode="constant")
        center = padded[1:-1, 1:-1]
        neighbors = (
            padded[:-2, 1:-1] & padded[2:, 1:-1] &
            padded[1:-1, :-2] & padded[1:-1, 2:]
        )
        return center.astype(bool) & (~neighbors.astype(bool))

    edge_canvas = np.zeros((h, w, 3), dtype=np.float32)
    edge_alpha = np.zeros((h, w, 1), dtype=np.float32)

    for ridx, region_name in enumerate(region_names):
        hard_region = label_np == ridx
        if not np.any(hard_region):
            continue

        area = float(hard_region.sum() / max(total, 1.0))
        if area < min_area_ratio:
            continue

        rgb = np.array(_hex_to_rgb01(MASK_PALETTE.get(region_name, "#C7D2DA")), dtype=np.float32)
        overlay[hard_region] = overlay[hard_region] * (1.0 - MASK_ALPHA) + rgb * MASK_ALPHA

        edge_mask = _mask_edge(hard_region)
        edge_rgb = np.clip(rgb * 0.72, 0.0, 1.0)
        edge_canvas[edge_mask] = edge_rgb
        edge_alpha[edge_mask] = MASK_EDGE_ALPHA

        legend_handles.append((region_name, rgb, area))

    overlay = overlay * (1.0 - edge_alpha) + edge_canvas * edge_alpha

    fig = plt.figure(figsize=(12.6, 6.5), facecolor=COLOR_FIG)
    gs = fig.add_gridspec(1, 2, width_ratios=[1.0, 1.0], wspace=0.03)
    ax0 = fig.add_subplot(gs[0, 0])
    ax1 = fig.add_subplot(gs[0, 1])

    for ax in (ax0, ax1):
        ax.set_facecolor(FIG_BG)
        ax.set_xticks([])
        ax.set_yticks([])
        for spine in ax.spines.values():
            spine.set_visible(False)

    ax0.imshow(image)
    ax0.set_title("Original image", fontsize=13, pad=10, color=TEXT_COLOR)

    ax1.imshow(overlay)
    ax1.set_title("Semantic region overlay (alpha=0.80)", fontsize=13, pad=10, color=TEXT_COLOR)

    legend_handles = sorted(legend_handles, key=lambda x: x[2], reverse=True)
    if legend_handles:
        import matplotlib.patches as mpatches
        patches = [
            mpatches.Patch(color=rgb, label=f"{region_display_name_en(name)} ({area:.1%})", alpha=MASK_ALPHA)
            for name, rgb, area in legend_handles
        ]
        fig.legend(
            handles=patches,
            loc="lower center",
            ncol=min(4, max(1, len(patches))),
            frameon=False,
            fontsize=10,
            bbox_to_anchor=(0.5, -0.02),
            columnspacing=1.4,
            handlelength=1.3,
        )

    fig.suptitle("Original image and semantic region overlay", fontsize=15, y=0.98, color=TEXT_COLOR)
    plt.tight_layout(rect=[0, 0.06, 1, 0.95])
    # 同时保存 SVG 和 PNG 两份
    p = Path(save_path)
    stem_dir = str(p.with_suffix(""))
    # PNG：真实像素图像，存 PNG 速度快、文件小
    plt.savefig(stem_dir + ".png", format="png", dpi=160, bbox_inches="tight", facecolor=fig.get_facecolor())
    # SVG：会把真实图像编码为 base64，文件较大，但矢量部分可缩放
    plt.savefig(stem_dir + ".svg", format="svg", bbox_inches="tight", facecolor=fig.get_facecolor())
    plt.close(fig)


