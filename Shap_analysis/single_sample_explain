def explain_single_sample_and_plot(
    *,
    model,
    outputs: Dict[str, torch.Tensor],
    bg_global: torch.Tensor,
    bg_region: torch.Tensor,
    region_names: Sequence[str],
    global_feature_names: Sequence[str],
    region_feature_names: Sequence[str],
    manual_forward_fn,
    save_dir: str,
    image_path: Optional[str] = None,
    semantic_mask: Optional[torch.Tensor] = None,
    conf_threshold: float = 0.55,
    min_area_ratio: float = 0.002,
    defect_threshold: float = 6.0,
    advantage_threshold: float = 7.5,
) -> Dict[str, Any]:
    _ensure_dir(save_dir)
    visual_detected_mask = visual_area_ratio = visual_peak_conf = None
    if outputs.get("image_region_soft_masks") is not None:
        visual_detected_mask, visual_area_ratio, visual_peak_conf = compute_visual_region_stats(
            outputs["image_region_soft_masks"], conf_threshold=conf_threshold, min_area_ratio=min_area_ratio
        )
        visual_detected_mask = visual_detected_mask.unsqueeze(0)
        visual_area_ratio = visual_area_ratio.unsqueeze(0)
        visual_peak_conf = visual_peak_conf.unsqueeze(0)

    engine = ExplainabilityEngineStrictOriginalDesign(
        region_names=region_names,
        global_feature_names=global_feature_names,
        region_feature_names=region_feature_names,
        manual_forward_fn=manual_forward_fn,
    )
    result = engine.explain(
        model=model,
        outputs=outputs,
        bg_global=bg_global,
        bg_region=bg_region,
        visual_detected_mask=visual_detected_mask,
        visual_area_ratio=visual_area_ratio,
        visual_peak_conf=visual_peak_conf,
        defect_threshold=defect_threshold,
        advantage_threshold=advantage_threshold,
    )

    if image_path and semantic_mask is not None:
        try:
            save_mask_overlay_visualization(
                image_path=image_path,
                semantic_mask=semantic_mask,
                region_names=region_names,
                save_path=os.path.join(save_dir, "semantic_mask_overlay.svg"),
                conf_threshold=conf_threshold,
                min_area_ratio=min_area_ratio,
            )
        except Exception as exc:
            print(f"[warn] failed to save semantic_mask_overlay.svg: {exc}")

    try:
        save_single_sample_waterfall(result, os.path.join(save_dir, "shap_waterfall.svg"), max_display=15)
    except Exception as exc:
        print(f"[warn] failed to save shap_waterfall.svg: {exc}")

    all_region_items = result["region_positive_features_flat"] + result["region_negative_features_flat"]
    save_local_bar_pretty(
        all_region_items,
        "Top region-related SHAP features for predicted image score",
        os.path.join(save_dir, "region_local_bar.svg"),
        top_k=12,
    )
    all_global_items = result["global_positive_features"] + result["global_negative_features"]
    save_local_bar_pretty(
        all_global_items,
        "Top global SHAP features for predicted image score",
        os.path.join(save_dir, "global_local_bar.svg"),
        top_k=10,
    )
    save_region_overview(result["region_explanations"], os.path.join(save_dir, "region_overview.svg"), defect_threshold=defect_threshold)
    save_region_feature_heatmap(
        result,
        region_names=region_names,
        region_feature_names=region_feature_names,
        save_path=os.path.join(save_dir, "region_feature_heatmap.svg"),
        use_abs=True,
    )

    for region_item in result["region_explanations"]:
        if not region_item["is_defect"]:
            continue
        lowest_items = region_item.get("lowest_features", [])
        if len(lowest_items) == 0:
            continue
        save_region_low_value_bar(
            lowest_items,
            title=f"{region_display_name_en(region_item['region_name'])} defect features (lowest raw values)",
            save_path=os.path.join(save_dir, f"defect_region_{region_item['region_name']}_bar.svg"),
            top_k=8,
        )
    return result


