    stem_dir = str(p.with_suffix(""))
    plt.savefig(stem_dir + ".svg", format="svg", bbox_inches="tight", facecolor=fig.get_facecolor())
    plt.savefig(stem_dir + ".png", format="png", dpi=200, bbox_inches="tight", facecolor=fig.get_facecolor())
