            )
    else:
        print("  - 无")

    print("\n参与评分的有效区域及其区域贡献（按原始设计定义）：")
    if result["valid_region_contributions"]:
        for item in sorted(result["valid_region_contributions"], key=lambda x: abs(x["region_contribution_score"]), reverse=True):
            score_text = "N/A" if item["region_score_10"] is None or np.isnan(item["region_score_10"]) else f"{item['region_score_10']:.2f}/10"
            print(
                f"  - {item['region_display_name']}: 面积占比 {item['area_ratio']:.3%}, 峰值置信度 {item['peak_confidence']:.3f}, "
