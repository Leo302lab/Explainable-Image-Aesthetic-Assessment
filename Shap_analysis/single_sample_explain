def safe_torch_load(
    path: str | os.PathLike[str],
    map_location: str | torch.device = "cpu",
    *,
    weights_only: bool = False,
) -> Any:
    try:
        return torch.load(path, map_location=map_location, weights_only=weights_only)
    except TypeError:
        return torch.load(path, map_location=map_location)


def region_display_name(region_name: str) -> str:
    return REGION_CN.get(region_name, region_name)


def feature_display_name(feature_name: str, region_name: Optional[str] = None) -> str:
    base = FEATURE_CN.get(feature_name, feature_name)
    return base if region_name is None else f"{region_display_name(region_name)}{base}"


def region_display_name_en(region_name: str) -> str:
    return REGION_EN.get(region_name, region_name)


def plot_label_from_feature_name(raw_name: str) -> str:
    raw_name = str(raw_name)
    if raw_name.startswith("global_"):
        base_feat = raw_name[len("global_"):]
        return f"Global {FEATURE_EN.get(base_feat, base_feat)}"
    for region_name in resolve_region_names():
        prefix = f"{region_name}_"
        if raw_name.startswith(prefix):
            base_feat = raw_name[len(prefix):]
            return f"{region_display_name_en(region_name)} {FEATURE_EN.get(base_feat, base_feat)}"
    return raw_name


def parse_feature_display_name_cn(raw_name: str, region_names: Sequence[str]) -> str:
    raw_name = str(raw_name)
    if raw_name.startswith("global_"):
        base_feat = raw_name[len("global_"):]
        return f"全局{FEATURE_CN.get(base_feat, base_feat)}"
    for region_name in region_names:
        prefix = f"{region_name}_"
        if raw_name.startswith(prefix):
            base_feat = raw_name[len(prefix):]
            return feature_display_name(base_feat, region_name)
    return raw_name


def is_global_feature_name(raw_name: str) -> bool:
    return str(raw_name).startswith("global_")


def is_region_feature_name(raw_name: str, region_names: Sequence[str]) -> bool:
    raw_name = str(raw_name)
    return any(raw_name.startswith(f"{r}_") for r in region_names)


def collect_flat_scope_features(
    shap_values: np.ndarray,
    feature_names: Sequence[str],
    feature_values: np.ndarray,
    region_names: Sequence[str],
    top_k: int = 8,
    scope: str = "all",
) -> Tuple[List[Dict[str, Any]], List[Dict[str, Any]]]:
    items: List[Dict[str, Any]] = []
    for name, sval, fval in zip(feature_names, shap_values, feature_values):
        raw_name = str(name)
        if raw_name.endswith("_valid") or raw_name.endswith("_area_ratio"):
            continue
        if scope == "global" and not is_global_feature_name(raw_name):
            continue
        if scope == "region" and not is_region_feature_name(raw_name, region_names):
            continue
        items.append(
            {
                "feature_name": raw_name,
                "feature_display_name": parse_feature_display_name_cn(raw_name, region_names),
                "feature_value": float(fval),
                "shap_value": float(sval),
            }
        )
    positive = sorted([x for x in items if x["shap_value"] > 0], key=lambda x: x["shap_value"], reverse=True)[:top_k]
    negative = sorted([x for x in items if x["shap_value"] < 0], key=lambda x: x["shap_value"])[:top_k]
    return positive, negative


def resolve_region_names() -> List[str]:
    labels = getattr(cfg, "SEMANTIC_LABELS", None)
    if isinstance(labels, dict):
        try:
            return [str(labels[i]) for i in sorted(labels.keys())]
        except Exception:
            return [str(v) for _, v in sorted(labels.items())]
    if isinstance(labels, (list, tuple)):
        return [str(x) for x in labels]
    return list(DEFAULT_REGION_NAMES)


def resolve_global_feature_names() -> List[str]:
    names = getattr(cfg, "GLOBAL_FEATURE_NAMES", None)
    if isinstance(names, (list, tuple)) and len(names) > 0:
        return [str(x) for x in names]
    core = getattr(cfg, "CORE_FEATURE_ORDER", None)
    if isinstance(core, (list, tuple)) and len(core) > 0:
        return [str(x) for x in core]
    global_dim = int(getattr(cfg, "GLOBAL_CORE_DIM", 12))
    return [f"global_feat_{i}" for i in range(global_dim)]


def resolve_region_feature_names() -> List[str]:
    names = getattr(cfg, "REGION_FEATURE_NAMES", None)
    if isinstance(names, (list, tuple)) and len(names) > 0:
        return [str(x) for x in names]
    core = list(getattr(cfg, "CORE_FEATURE_ORDER", [f"region_feat_{i}" for i in range(12)]))
    meta = list(getattr(cfg, "CSV_SUB_FEATS", ["valid", "area_ratio"]))
    return [str(x) for x in (core + meta)]


