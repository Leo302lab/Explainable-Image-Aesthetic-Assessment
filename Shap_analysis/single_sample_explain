def compute_visual_region_stats(
    image_region_soft_masks: torch.Tensor,
    conf_threshold: float = 0.55,
    min_area_ratio: float = 0.002,
) -> Tuple[torch.Tensor, torch.Tensor, torch.Tensor]:
    masks = image_region_soft_masks[0]
    conf_map = masks.max(dim=0).values
    label_map = masks.argmax(dim=0)
    total = float(label_map.numel())

    detected = []
    area_ratios = []
    peak_confs = []
    for ridx in range(masks.size(0)):
        region_conf = masks[ridx]
        peak_conf = float(region_conf.max().item())
        area = (((label_map == ridx) & (conf_map >= conf_threshold)).sum().item()) / max(total, 1.0)
        is_detected = (peak_conf >= conf_threshold) and (area >= min_area_ratio)
        detected.append(is_detected)
        area_ratios.append(area)
        peak_confs.append(peak_conf)

    device = image_region_soft_masks.device
    return (
        torch.tensor(detected, dtype=torch.bool, device=device),
        torch.tensor(area_ratios, dtype=torch.float32, device=device),
        torch.tensor(peak_confs, dtype=torch.float32, device=device),
    )


