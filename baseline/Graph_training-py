class ResNetSpatialBackbone(nn.Module):
    """ResNet50 backbone returning spatial feature map [B,2048,H,W]."""

    def __init__(self, ckpt_path: Optional[str] = None):
        super().__init__()
        backbone = resnet50(weights=None)
        safe_load_module(backbone, ckpt_path, name="ResNet50")

        # 去掉 avgpool 和 fc，保留空间 feature map
        self.features = nn.Sequential(*list(backbone.children())[:-2])
        self.out_dim = 2048

    def forward(self, x):
        return self.features(x)


class AvgPoolFCHead(nn.Module):
    def __init__(self, in_dim=2048, hidden_dim=512, dropout=0.1):
        super().__init__()
        self.net = nn.Sequential(
            nn.AdaptiveAvgPool2d((1, 1)),
            nn.Flatten(),
            nn.Linear(in_dim, hidden_dim),
            nn.GELU(),
            nn.Dropout(dropout),
            nn.LayerNorm(hidden_dim),
            nn.Linear(hidden_dim, 1),
        )
        self._init_last()

    def _init_last(self):
        last = self.net[-1]
        if isinstance(last, nn.Linear):
            nn.init.normal_(last.weight, mean=0.0, std=0.01)
            nn.init.constant_(last.bias, 0.0)

    def forward(self, x):
        return self.net(x)


class SpatialGCNHead(nn.Module):
    """纯 PyTorch 空间图卷积近似。
    将 H×W 位置视为规则图节点，3×3 conv 相当于局部邻接消息传递。
    """

    def __init__(self, in_dim=2048, hidden_dim=512, dropout=0.1):
        super().__init__()
        self.proj = nn.Sequential(
            nn.Conv2d(in_dim, hidden_dim, kernel_size=1, bias=False),
            nn.BatchNorm2d(hidden_dim),
            nn.GELU(),
        )
        self.gcn1 = nn.Sequential(
            nn.Conv2d(hidden_dim, hidden_dim, kernel_size=3, padding=1, bias=False),
            nn.BatchNorm2d(hidden_dim),
            nn.GELU(),
        )
        self.gcn2 = nn.Sequential(
            nn.Conv2d(hidden_dim, hidden_dim, kernel_size=3, padding=1, bias=False),
            nn.BatchNorm2d(hidden_dim),
            nn.GELU(),
        )
        self.regressor = nn.Sequential(
            nn.AdaptiveAvgPool2d((1, 1)),
            nn.Flatten(),
            nn.Linear(hidden_dim, hidden_dim // 2),
            nn.GELU(),
            nn.Dropout(dropout),
            nn.LayerNorm(hidden_dim // 2),
            nn.Linear(hidden_dim // 2, 1),
        )
        self._init_last()

    def _init_last(self):
        last = self.regressor[-1]
        if isinstance(last, nn.Linear):
            nn.init.normal_(last.weight, mean=0.0, std=0.01)
            nn.init.constant_(last.bias, 0.0)

    def forward(self, x):
        h = self.proj(x)
        h = self.gcn1(h) + h
        h = self.gcn2(h) + h
        return self.regressor(h)


class SpatialGATHead(nn.Module):
    """纯 PyTorch 空间 GAT 近似。
    将 H×W 空间位置作为节点，对所有节点做多头自注意力。
    """

    def __init__(self, in_dim=2048, hidden_dim=512, heads=4, dropout=0.1):
        super().__init__()
        if hidden_dim % heads != 0:
            raise ValueError("hidden_dim must be divisible by heads.")

        self.hidden_dim = hidden_dim
        self.heads = heads
        self.head_dim = hidden_dim // heads
        self.scale = self.head_dim ** -0.5

        self.proj = nn.Sequential(
            nn.Conv2d(in_dim, hidden_dim, kernel_size=1, bias=False),
            nn.BatchNorm2d(hidden_dim),
            nn.GELU(),
        )

        self.qkv = nn.Linear(hidden_dim, hidden_dim * 3)
        self.out_proj = nn.Linear(hidden_dim, hidden_dim)

        self.regressor = nn.Sequential(
            nn.LayerNorm(hidden_dim),
            nn.Linear(hidden_dim, hidden_dim // 2),
            nn.GELU(),
            nn.Dropout(dropout),
            nn.Linear(hidden_dim // 2, 1),
        )
        self._init_last()

    def _init_last(self):
        last = self.regressor[-1]
        if isinstance(last, nn.Linear):
            nn.init.normal_(last.weight, mean=0.0, std=0.01)
            nn.init.constant_(last.bias, 0.0)

    def forward(self, x):
        # x: [B,C,H,W]
        h = self.proj(x)
        B, C, H, W = h.shape
        N = H * W

        nodes = h.flatten(2).transpose(1, 2)  # [B,N,C]
        qkv = self.qkv(nodes).reshape(B, N, 3, self.heads, self.head_dim)
        qkv = qkv.permute(2, 0, 3, 1, 4)  # [3,B,heads,N,head_dim]
        q, k, v = qkv[0], qkv[1], qkv[2]

        attn = (q @ k.transpose(-2, -1)) * self.scale
        attn = F.softmax(attn, dim=-1)

        out = attn @ v  # [B,heads,N,head_dim]
        out = out.transpose(1, 2).reshape(B, N, C)
        out = self.out_proj(out)

        graph_repr = out.mean(dim=1)
        return self.regressor(graph_repr)


class ResNetGraphBaseline(nn.Module):
    def __init__(
        self,
        graph_model: str = "gcn",
        hidden_dim: int = 512,
        gat_heads: int = 4,
        dropout: float = 0.1,
        resnet_ckpt: Optional[str] = None,
    ):
        super().__init__()
        self.backbone = ResNetSpatialBackbone(ckpt_path=resnet_ckpt)

        if graph_model == "avg_pool":
            self.head = AvgPoolFCHead(in_dim=self.backbone.out_dim, hidden_dim=hidden_dim, dropout=dropout)
        elif graph_model == "gcn":
            self.head = SpatialGCNHead(in_dim=self.backbone.out_dim, hidden_dim=hidden_dim, dropout=dropout)
        elif graph_model == "gat":
            self.head = SpatialGATHead(in_dim=self.backbone.out_dim, hidden_dim=hidden_dim, heads=gat_heads, dropout=dropout)
        else:
            raise ValueError(f"Unknown graph_model: {graph_model}")

    def forward(self, x):
        feats = self.backbone(x)
        score = self.head(feats).view(-1)
        if not ARGS.no_sigmoid:
            score = torch.sigmoid(score)
        return score


def freeze_backbone_keep_head(model: nn.Module):
    for p in model.backbone.parameters():
        p.requires_grad = False
    for p in model.head.parameters():
        p.requires_grad = True

    frozen = sum(p.numel() for p in model.backbone.parameters())
    trainable = sum(p.numel() for p in model.head.parameters() if p.requires_grad)
    print(f"🧊 Freeze backbone: frozen={frozen:,}, head trainable={trainable:,}")


def unfreeze_all(model: nn.Module):
    for p in model.parameters():
        p.requires_grad = True
    print("🔥 Unfreeze all parameters.")


