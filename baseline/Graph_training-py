# 7. Optimizer / Loss
# ============================================================
def make_optimizer(model: nn.Module, lr_backbone: float, lr_head: float, weight_decay: float):
    backbone_decay, backbone_no_decay = [], []
    head_decay, head_no_decay = [], []

    for name, p in model.named_parameters():
        if not p.requires_grad:
            continue

        is_head = name.startswith("head.")
        no_decay = (
            p.ndim <= 1
            or name.endswith(".bias")
            or "norm" in name.lower()
            or "bn" in name.lower()
        )

        if is_head:
            if no_decay:
                head_no_decay.append(p)
            else:
                head_decay.append(p)
        else:
            if no_decay:
                backbone_no_decay.append(p)
            else:
                backbone_decay.append(p)

    groups = []
    if backbone_decay:
        groups.append({"params": backbone_decay, "lr": lr_backbone, "weight_decay": weight_decay})
    if backbone_no_decay:
        groups.append({"params": backbone_no_decay, "lr": lr_backbone, "weight_decay": 0.0})
    if head_decay:
        groups.append({"params": head_decay, "lr": lr_head, "weight_decay": weight_decay})
    if head_no_decay:
        groups.append({"params": head_no_decay, "lr": lr_head, "weight_decay": 0.0})

    if not groups:
        raise RuntimeError("No trainable parameters found.")

    optimizer = optim.AdamW(groups)

    print("\n🧩 Optimizer groups:")
    for i, g in enumerate(optimizer.param_groups):
        n_params = sum(p.numel() for p in g["params"])
        print(f"   group {i}: params={n_params:,}, lr={g['lr']:.2e}, wd={g['weight_decay']:.2e}")

    return optimizer


def regression_loss(pred: torch.Tensor, target: torch.Tensor):
    if GLOBAL_LOSS_TYPE == "mse":
        return F.mse_loss(pred, target)
    return F.smooth_l1_loss(pred, target, beta=GLOBAL_LOSS_BETA)


# ============================================================
# 8. Train / Validate / Test
# ============================================================
def train_one_epoch(
    model,
    loader,
    optimizer,
    scaler,
    epoch: int,
    accumulation_steps: int,
    amp_enabled: bool,
    max_batches: Optional[int] = None,
):
    model.train()

    total_loss = 0.0
    valid_batches = 0
    all_preds, all_targets = [], []

    optimizer.zero_grad(set_to_none=True)
    pbar = tqdm(loader, desc=f"Ep {epoch} [Train]", leave=False)

    for i, batch in enumerate(pbar):
        if max_batches is not None and i >= max_batches:
            break

        images = batch["image"].to(DEVICE).float()
        targets = batch["label"].to(DEVICE).float().view(-1)

        with autocast(device_type=DEVICE.type, enabled=amp_enabled):
            preds = model(images).view(-1)
            loss = regression_loss(preds, targets)

        if torch.isnan(loss) or torch.isinf(loss):
            print("⚠️ NaN/Inf loss detected, skip batch.")
            optimizer.zero_grad(set_to_none=True)
            continue

        scaler.scale(loss / accumulation_steps).backward()

        if (i + 1) % accumulation_steps == 0:
            scaler.unscale_(optimizer)
            torch.nn.utils.clip_grad_norm_(model.parameters(), GRADIENT_CLIP)
            scaler.step(optimizer)
            scaler.update()
            optimizer.zero_grad(set_to_none=True)

        total_loss += float(loss.item())
        valid_batches += 1
        all_preds.append(preds.detach().cpu().numpy())
        all_targets.append(targets.detach().cpu().numpy())

        if i % 10 == 0:
            batch_metrics = compute_metrics(preds.detach().cpu().numpy(), targets.detach().cpu().numpy())
            pbar.set_postfix({
                "loss": f"{loss.item():.4f}",
                "srcc": f"{batch_metrics['spearman']:.3f}",
                "pcc": f"{batch_metrics['pearson']:.3f}",
            })

    if valid_batches == 0:
        return {"pearson": 0.0, "spearman": 0.0, "mse": 0.0, "mae": 0.0}, 0.0

    preds_np = np.concatenate(all_preds)
    targets_np = np.concatenate(all_targets)

    metrics = compute_metrics(preds_np, targets_np)
    avg_loss = total_loss / valid_batches

    print(
        f"📊 [Train] Ep {epoch}: "
        f"Loss={avg_loss:.4f} | SRCC={metrics['spearman']:.4f} | PCC={metrics['pearson']:.4f} | "
        f"MSE={metrics['mse']:.4f} | MAE={metrics['mae']:.4f} | "
        f"pred_mean={preds_np.mean():.4f}, pred_std={preds_np.std():.4f}, "
        f"target_mean={targets_np.mean():.4f}, target_std={targets_np.std():.4f}"
    )

    return metrics, avg_loss


@torch.no_grad()
def validate(
    model,
    loader,
    epoch,
    amp_enabled: bool,
    desc: str = "[Val]",
    max_batches: Optional[int] = None,
):
    model.eval()

    total_loss = 0.0
    valid_batches = 0
    all_preds, all_targets = [], []

    pbar = tqdm(loader, desc=f"Ep {epoch} {desc}", leave=False)

    for i, batch in enumerate(pbar):
        if max_batches is not None and i >= max_batches:
            break

        images = batch["image"].to(DEVICE).float()
        targets = batch["label"].to(DEVICE).float().view(-1)

        with autocast(device_type=DEVICE.type, enabled=amp_enabled):
            preds = model(images).view(-1)
            loss = regression_loss(preds, targets)

        total_loss += float(loss.item())
        valid_batches += 1
        all_preds.append(preds.detach().cpu().numpy())
        all_targets.append(targets.detach().cpu().numpy())

    if valid_batches == 0:
        return {"pearson": 0.0, "spearman": 0.0, "mse": 0.0, "mae": 0.0}, 0.0

    preds_np = np.concatenate(all_preds)
    targets_np = np.concatenate(all_targets)

    metrics = compute_metrics(preds_np, targets_np)
    avg_loss = total_loss / valid_batches

    print(
        f"✨ {desc} Ep {epoch}: "
        f"Loss={avg_loss:.4f} | SRCC={metrics['spearman']:.4f} | PCC={metrics['pearson']:.4f} | "
        f"MSE={metrics['mse']:.4f} | MAE={metrics['mae']:.4f} | "
        f"pred_mean={preds_np.mean():.4f}, pred_std={preds_np.std():.4f}, "
        f"target_mean={targets_np.mean():.4f}, target_std={targets_np.std():.4f}"
    )

    return metrics, avg_loss


@torch.no_grad()
def test_evaluate(model, loader, amp_enabled: bool, save_path: Optional[str] = None):
    model.eval()

    all_preds, all_targets = [], []
    all_image_ids = []
    acc_tols = (0.5, 1.0)
    acc_names = ("acc@0.5", "acc@1.0")

    for batch in tqdm(loader, desc="[Test]", leave=False):
        images = batch["image"].to(DEVICE).float()

        with autocast(device_type=DEVICE.type, enabled=amp_enabled):
            pred_norm = model(images).view(-1)

        if ARGS.test_clamp:
            pred_norm = pred_norm.clamp(0.0, 1.0)

        if "label_raw" in batch:
            target = batch["label_raw"].to(DEVICE).float().view(-1)
            pred = pred_norm * 9.0 + 1.0
        else:
            target = batch["label"].to(DEVICE).float().view(-1) * 9.0 + 1.0
            pred = pred_norm * 9.0 + 1.0

        all_preds.append(pred.detach().cpu().numpy())
        all_targets.append(target.detach().cpu().numpy())

        if "image_id" in batch:
            ids = batch["image_id"]
            if isinstance(ids, list):
                all_image_ids.extend([str(x) for x in ids])
            else:
                all_image_ids.extend([str(x.item()) if hasattr(x, "item") else str(x) for x in ids])
        else:
            bs = pred_norm.shape[0]
            start = sum(len(a) for a in all_preds[:-1])
            all_image_ids.extend([f"idx_{start + j}" for j in range(bs)])

    preds_np = np.concatenate(all_preds)
    targets_np = np.concatenate(all_targets)

    metrics = compute_metrics(preds_np, targets_np, acc_tols=acc_tols, acc_names=acc_names)

    print(
        f"🧪 [Test Diagnostics] pred_mean={preds_np.mean():.4f}, pred_std={preds_np.std():.4f}, "
        f"pred_min={preds_np.min():.4f}, pred_max={preds_np.max():.4f}, "
        f"target_mean={targets_np.mean():.4f}, target_std={targets_np.std():.4f}, "
        f"target_min={targets_np.min():.4f}, target_max={targets_np.max():.4f}"
    )

    if save_path and len(all_image_ids) == len(preds_np):
        os.makedirs(os.path.dirname(save_path), exist_ok=True)
        df = pd.DataFrame({
            "image_id": all_image_ids,
            "label_raw": targets_np,
            "pred_raw": preds_np,
        })
        df.to_csv(save_path, index=False)
        print(f"💾 Per-sample predictions saved: {save_path} ({len(df)} rows)")

    return metrics


