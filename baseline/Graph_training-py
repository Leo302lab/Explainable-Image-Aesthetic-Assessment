def compute_metrics(
    preds_np: np.ndarray,
    targets_np: np.ndarray,
    acc_tols: Tuple[float, float] = (0.05, 0.10),
    acc_names: Tuple[str, str] = ("acc@0.05", "acc@0.10"),
) -> Dict[str, float]:
    preds = preds_np.astype(float).reshape(-1)
    targets = targets_np.astype(float).reshape(-1)

    pred_std = float(np.std(preds))
    target_std = float(np.std(targets))

    if preds.shape[0] < 2:
        metrics = {
            "pearson": 0.0, "spearman": 0.0, "mse": 0.0, "mae": 0.0,
            "pred_std": pred_std, "target_std": target_std,
        }
        for _, name in zip(acc_tols, acc_names):
            metrics[name] = 0.0
        return metrics

    if pred_std < 1e-12 or target_std < 1e-12:
        pcc = 0.0
    else:
        pcc = float(np.corrcoef(preds, targets)[0, 1])
        if np.isnan(pcc):
            pcc = 0.0

    if pred_std < 1e-12 or target_std < 1e-12 or len(np.unique(preds)) < 2 or len(np.unique(targets)) < 2:
        srcc = 0.0
    else:
        srcc = float(spearmanr(preds, targets).correlation)
        if np.isnan(srcc):
            srcc = 0.0

    diff = preds - targets
    abs_diff = np.abs(diff)

    metrics = {
        "pearson": pcc,
        "spearman": srcc,
        "mse": float(np.mean(diff ** 2)),
        "mae": float(np.mean(abs_diff)),
        "pred_std": pred_std,
        "target_std": target_std,
    }

    for tol, name in zip(acc_tols, acc_names):
        metrics[name] = float(np.sum(abs_diff <= tol)) / len(abs_diff)

    return metrics


def compute_selection_score(metrics: Dict[str, float], srcc_weight: float = BEST_METRIC_SRCC_WEIGHT) -> float:
    return float(srcc_weight) * float(metrics["spearman"]) + (1.0 - float(srcc_weight)) * float(metrics["pearson"])


