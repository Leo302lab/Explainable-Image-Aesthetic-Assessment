def extract_state_dict(ckpt):
    if isinstance(ckpt, dict):
        for key in ("state_dict", "model_state_dict", "model", "net"):
            if key in ckpt and isinstance(ckpt[key], dict):
                return ckpt[key]
    return ckpt


def strip_prefix_levels(state_dict, levels: int):
    out = {}
    for key, value in state_dict.items():
        parts = key.split(".")
        new_key = ".".join(parts[levels:]) if len(parts) > levels else key
        out[new_key] = value
    return out


def align_state_dict_to_module(module: nn.Module, raw_state_dict):
    target_keys = set(module.state_dict().keys())
    cleaned = {key.replace("module.", ""): value for key, value in raw_state_dict.items()}

    best_overlap = -1
    best_state = cleaned

    for levels in range(5):
        candidate = cleaned if levels == 0 else strip_prefix_levels(cleaned, levels)
        overlap = len(set(candidate.keys()) & target_keys)
        if overlap > best_overlap:
            best_overlap = overlap
            best_state = candidate

    filtered = {
        k: v for k, v in best_state.items()
        if k in target_keys and module.state_dict()[k].shape == v.shape
    }
    return filtered, best_overlap


def safe_load_module(module: nn.Module, ckpt_path: Optional[str], name: str):
    if not ckpt_path:
        print(f"⚠️ [{name}] no checkpoint path. Using random initialization.")
        return

    if not os.path.isfile(ckpt_path):
        print(f"⚠️ [{name}] checkpoint not found: {ckpt_path}")
        return

    ckpt = torch.load(ckpt_path, map_location="cpu")
    state_dict = extract_state_dict(ckpt)
    filtered, matched = align_state_dict_to_module(module, state_dict)

    missing, unexpected = module.load_state_dict(filtered, strict=False)
    print(f"✅ [{name}] loaded checkpoint: {ckpt_path}")
    print(f"   matched keys: {matched}, loaded shape-matched keys: {len(filtered)}")
    if missing:
        print(f"   missing keys: {len(missing)}")
    if unexpected:
        print(f"   unexpected keys: {len(unexpected)}")


