def build_dataloaders(seed: int, batch_size: int, num_workers: int):
    g = torch.Generator()
    g.manual_seed(seed)

    common_kwargs = dict(
        batch_size=batch_size,
        num_workers=num_workers,
        pin_memory=DEFAULT_PIN_MEMORY,
        worker_init_fn=seed_worker if num_workers > 0 else None,
        run_tag="default",
        strict_scaler=True,
    )

    train_loader = get_feature_dataloader(
        split=TRAIN_SPLIT,
        shuffle=True,
        generator=g,
        **common_kwargs,
    )
    val_loader = get_feature_dataloader(
        split=VAL_SPLIT,
        shuffle=False,
        generator=g,
        **common_kwargs,
    )
    test_loader = get_feature_dataloader(
        split=TEST_SPLIT,
        shuffle=False,
        generator=g,
        **common_kwargs,
    )

    return train_loader, val_loader, test_loader


